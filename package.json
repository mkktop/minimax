{
  "name": "minimax-quota-monitor",
  "displayName": "MiniMax API配额监控",
  "description": "在 VSCode 状态栏监控 MiniMax API 配额使用情况",
  "version": "1.0.1",
  "publisher": "mkktop",
  "repository": {
    "type": "git",
    "url": "https://github.com/mkktop/minimax-quota-monitor"
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "minimax",
    "api",
    "quota",
    "monitor",
    "statusbar"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "minimaxQuota.setApiKey",
        "title": "MiniMax: Set API Key"
      },
      {
        "command": "minimaxQuota.refreshQuota",
        "title": "MiniMax: Refresh Quota"
      },
      {
        "command": "minimaxQuota.setRefreshInterval",
        "title": "MiniMax: Set Refresh Interval"
      }
    ],
    "configuration": {
      "title": "MiniMax Quota Monitor",
      "properties": {
        "minimaxQuotaMonitor.apiKey": {
          "type": "string",
          "default": "",
          "description": "MiniMax API Key"
        },
        "minimaxQuotaMonitor.refreshInterval": {
          "type": "number",
          "default": 300,
          "description": "Refresh interval in seconds (minimum 10)"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.74.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
